# Copy this file to ".deploy_secret" in your project root (it is gitignored).
# It is PARSED, not executed: only DEPLOY_URL and DEPLOY_TOKEN are read.
# DEPLOY_URL must be https:// (the token travels in a request header).
DEPLOY_URL="https://your-site.example/path/phpush.php"
DEPLOY_TOKEN="paste-the-same-token-you-set-in-phpush.php-on-the-server"
